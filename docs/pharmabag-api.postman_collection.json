{
  "info": {
    "name": "PharmaBag API",
    "description": "B2B Pharmaceutical Marketplace API — Complete endpoint collection.\n\nBase URL: {{baseUrl}} (default http://localhost:3000/api)\nSwagger Docs: http://localhost:3000/api/docs\n\nTest credentials:\n- Buyer: 7777777777\n- Seller: 8888888888\n- Admin: 9999999999\n\nOTP in dev mode is logged to console. Retrieve from Redis: redis-cli GET otp:<phone>",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "buyerToken", "value": "" },
    { "key": "sellerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "settlementId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/send-otp",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"7777777777\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  const phone = JSON.parse(pm.request.body.raw).phone;",
                  "  if (phone === '7777777777') pm.collectionVariables.set('buyerToken', res.accessToken);",
                  "  if (phone === '8888888888') pm.collectionVariables.set('sellerToken', res.accessToken);",
                  "  if (phone === '9999999999') pm.collectionVariables.set('adminToken', res.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verify-otp",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"7777777777\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token-here\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
