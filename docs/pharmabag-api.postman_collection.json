            "body": {
              "mode": "raw",
              "raw": "{\n  \"legalName\": \"MedPlus Pharmacy Pvt Ltd\",\n  \"gstNumber\": \"27AABCU9603R1ZM\",\n  \"panNumber\": \"ABCDE1234F\",\n  \"drugLicenseNumber\": \"DL-MH-2024-001234\",\n  \"drugLicenseUrl\": \"https://example.com/drug-license.pdf\",\n  \"address\": \"123 MG Road\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"pincode\": \"400001\",\n  \"latitude\": 19.076,\n  \"longitude\": 72.8777\n}"
            }
