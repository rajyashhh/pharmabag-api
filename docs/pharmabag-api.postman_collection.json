    {
      "name": "Products",
      "item": [
        {
          "name": "List Products (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=20&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortOrder", "value": "desc" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "subCategoryId", "value": "", "disabled": true },
                { "key": "manufacturer", "value": "", "disabled": true }
              ]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/categories",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Create Product (Seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('productId', res.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{sellerToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paracetamol 500mg\",\n  \"categoryId\": \"uuid-of-category\",\n  \"subCategoryId\": \"uuid-of-subcategory\",\n  \"manufacturer\": \"Cipla Ltd\",\n  \"chemicalComposition\": \"Paracetamol IP 500mg\",\n  \"description\": \"Analgesic and antipyretic tablet\",\n  \"mrp\": 25.50,\n  \"gstPercent\": 12,\n  \"minimumOrderQuantity\": 10,\n  \"maximumOrderQuantity\": 1000,\n  \"stock\": 500,\n  \"expiryDate\": \"2026-12-31\"\n}"
            }
          }
        },
