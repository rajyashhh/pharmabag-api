            "url": "{{baseUrl}}/products/{{productId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{sellerToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paracetamol 650mg\",\n  \"mrp\": 30.00,\n  \"stock\": 450\n}"
            }
          }
        },
        {
