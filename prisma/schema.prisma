// ============================================================
// PharmaBag - B2B Pharmaceutical Marketplace
// Production-Grade PostgreSQL Schema (Prisma ORM)
// Designed for 100k–1M+ daily users, multi-vendor commerce
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PLACED
  ACCEPTED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  SUCCESS
  FAILED
}

enum PaymentMethod {
  BANK_TRANSFER
  UPI
  COD
  PARTIAL
  CREDIT
}

enum PaymentVerificationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AlertType {
  NEAR_EXPIRY
  OUT_OF_STOCK
}

enum DiscountType {
  PTR_DISCOUNT
  SAME_PRODUCT_BONUS
  PTR_PLUS_SAME_PRODUCT_BONUS
  DIFFERENT_PRODUCT_BONUS
  PTR_PLUS_DIFFERENT_PRODUCT_BONUS
}

// ──────────────────────────────────────────────
// MIGRATION TRACKING
// ──────────────────────────────────────────────

enum MigrationEntityType {
  USER
  ORDER
  PAYMENT
  ORDER_ITEM
  SETTLEMENT
}

enum MigrationStatus {
  RUNNING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum MigrationRecordStatus {
  SUCCESS
  SKIPPED
  FAILED
}

/// Tracks each migration batch run for auditability and rollback
model MigrationRun {
  id          String          @id @default(uuid())
  entityType  MigrationEntityType
  status      MigrationStatus @default(RUNNING)
  totalRecords Int            @default(0)
  successCount Int            @default(0)
  failedCount  Int            @default(0)
  skippedCount Int            @default(0)
  metadata    Json?           // Run-level metadata (source file, operator, etc.)
  errorSummary String?        // Aggregated error summary
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  rolledBackAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  records MigrationRecord[]

  @@index([entityType])
  @@index([status])
  @@index([startedAt])
  @@map("migration_runs")
}

/// Per-record audit log for migration — enables rollback and debugging
model MigrationRecord {
  id             String                @id @default(uuid())
  runId          String
  entityType     MigrationEntityType
  legacyId       String                // Original ID from legacy system
  newId          String?               // New UUID in Pharmabag v2
  status         MigrationRecordStatus @default(SUCCESS)
  errorMessage   String?
  rawData        Json?                 // Original legacy record (for debugging)
  createdAt      DateTime              @default(now())

  run MigrationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([entityType, legacyId])     // Prevent duplicate imports
  @@index([runId])
  @@index([entityType, legacyId])
  @@index([entityType, newId])
  @@index([status])
  @@map("migration_records")
}

/// Lookup table mapping legacy IDs to new v2 UUIDs (fast O(1) resolution)
model MigrationIdMap {
  id         String              @id @default(uuid())
  entityType MigrationEntityType
  legacyId   String              // Legacy system ID
  newId      String              // New Pharmabag v2 UUID
  createdAt  DateTime            @default(now())

  @@unique([entityType, legacyId])
  @@index([entityType, newId])
  @@map("migration_id_map")
}

// ──────────────────────────────────────────────
// CORE IDENTITY
// ──────────────────────────────────────────────

model User {
  id        String     @id @default(uuid())
  phone     String     @unique
  email     String?    @unique
  password  String
  role      Role
  status    UserStatus @default(PENDING)
  legacyId  String?    @unique // Legacy system ID for migration traceability
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // One-to-one profiles
  buyerProfile  BuyerProfile?
  sellerProfile SellerProfile?
  adminProfile  AdminProfile?

  // Relations
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  tickets       Ticket[]
  messages      Message[]

  @@index([role])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("users")
}

// ──────────────────────────────────────────────
// BUYER PROFILE
// ──────────────────────────────────────────────

model BuyerProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  legalName         String
  gstNumber         String
  panNumber         String
  drugLicenseNumber String
  drugLicenseUrl    String // S3 URL to uploaded license document
  address           String
  city              String
  state             String
  pincode           String
  latitude          Float? // For nearby seller search
  longitude         Float? // For nearby seller search
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([state])
  @@index([pincode])
  @@map("buyer_profiles")
}

// ──────────────────────────────────────────────
// SELLER PROFILE
// ──────────────────────────────────────────────

model SellerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  companyName        String
  gstNumber          String
  panNumber          String
  drugLicenseNumber  String
  drugLicenseUrl     String // S3 URL to uploaded license document
  address            String
  city               String
  state              String
  pincode            String
  isVacation         Boolean            @default(false)
  rating             Float              @default(0)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]
  orderItems  OrderItem[]
  settlements SellerSettlement[]

  @@index([city])
  @@index([state])
  @@index([verificationStatus])
  @@index([isVacation])
  @@map("seller_profiles")
}

// ──────────────────────────────────────────────
// ADMIN PROFILE
// ──────────────────────────────────────────────

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String
  department  String?
  permissions String   @default("")  // Space-separated permission codes: "1 3 5 7 x" where x=super-admin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_profiles")
}

// ──────────────────────────────────────────────
// CATEGORY SYSTEM (Hierarchical)
// ──────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  subCategories SubCategory[]
  products      Product[]

  @@map("categories")
}

model SubCategory {
  id         String   @id @default(uuid())
  name       String
  slug       String
  categoryId String
  createdAt  DateTime @default(now())

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([slug, categoryId])
  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("sub_categories")
}

// ──────────────────────────────────────────────
// PRODUCT CATALOG
// ──────────────────────────────────────────────

model Product {
  id                   String        @id @default(uuid())
  sellerId             String
  categoryId           String
  subCategoryId        String
  name                 String
  slug                 String?       @unique
  externalId           String?       @unique // Legacy MongoDB ObjectId for migration idempotency
  manufacturer         String
  chemicalComposition  String
  description          String?
  mrp                  Float
  gstPercent           Float
  minimumOrderQuantity Int           @default(1)
  maximumOrderQuantity Int?
  discountType         DiscountType?
  discountMeta         Json?         // Flexible JSON for discount parameters
  isActive             Boolean       @default(true)
  deletedAt            DateTime?     // Soft delete
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  seller      SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category    Category       @relation(fields: [categoryId], references: [id])
  subCategory SubCategory    @relation(fields: [subCategoryId], references: [id])
  batches     ProductBatch[]
  images      ProductImage[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]

  // Hidden infrastructure (Phase-2+)
  searchIndex     ProductSearchIndex?
  analytics       ProductAnalytics?
  inventoryAlerts InventoryAlert[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([isActive])
  @@index([name])
  @@index([manufacturer])
  @@index([deletedAt])
  @@index([externalId])
  @@index([name, manufacturer])
  @@index([categoryId, subCategoryId])
  @@map("products")
}

// ──────────────────────────────────────────────
// PRODUCT IMAGES
// ──────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String // S3 URL
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ──────────────────────────────────────────────
// CART SYSTEM
// ──────────────────────────────────────────────

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId]) // Prevent duplicate products in same cart
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ──────────────────────────────────────────────
// ORDER SYSTEM (Multi-Seller Support)
// ──────────────────────────────────────────────

model Order {
  id            String        @id @default(uuid())
  buyerId       String
  totalAmount   Float
  orderStatus   OrderStatus   @default(PLACED)
  paymentStatus PaymentStatus @default(PENDING)
  legacyId      String?       @unique // Legacy system order ID
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  buyer    User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  address  OrderAddress?
  items    OrderItem[]
  payments Payment[]

  @@index([buyerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  sellerId   String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  legacyId   String?  @unique // Legacy system order item ID
  createdAt  DateTime @default(now())

  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id])
  seller     SellerProfile     @relation(fields: [sellerId], references: [id])
  settlement SellerSettlement?

  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
  @@map("order_items")
}

// ──────────────────────────────────────────────
// PAYMENT SYSTEM
// ──────────────────────────────────────────────

model Payment {
  id                 String                    @id @default(uuid())
  orderId            String
  amount             Float
  method             PaymentMethod
  referenceNumber    String?
  proofUrl           String?
  verificationStatus PaymentVerificationStatus @default(PENDING)
  legacyId           String?                   @unique // Legacy system payment ID
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([verificationStatus])
  @@map("payments")
}

// ──────────────────────────────────────────────
// REVIEWS
// ──────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // One review per user per product
  @@index([productId])
  @@index([rating])
  @@map("reviews")
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// SUPPORT TICKET SYSTEM
// ──────────────────────────────────────────────

model Ticket {
  id        String       @id @default(uuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model Message {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("messages")
}

// ──────────────────────────────────────────────
// ORDER ADDRESS (Delivery snapshot)
// ──────────────────────────────────────────────

model OrderAddress {
  id      String @id @default(uuid())
  orderId String @unique
  name    String
  phone   String
  address String
  city    String
  state   String
  pincode String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

// ──────────────────────────────────────────────
// PRODUCT BATCHES (Pharma inventory tracking)
// ──────────────────────────────────────────────

model ProductBatch {
  id          String   @id @default(uuid())
  productId   String
  batchNumber String
  expiryDate  DateTime
  stock       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryAlerts InventoryAlert[]

  @@index([productId])
  @@index([expiryDate])
  @@index([productId, batchNumber])
  @@map("product_batches")
}

// ──────────────────────────────────────────────
// PRODUCT SEARCH INDEX (Hidden — Phase-2+)
// Fast full-text search & autocomplete
// ──────────────────────────────────────────────

model ProductSearchIndex {
  id                  String   @id @default(uuid())
  productId           String   @unique
  name                String
  manufacturer        String
  chemicalComposition String
  categoryName        String
  subCategoryName     String
  searchVector        String // Concatenated lowercase search string
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([manufacturer])
  @@index([searchVector])
  @@index([categoryName])
  @@map("product_search_index")
}

// ──────────────────────────────────────────────
// PRODUCT ANALYTICS (Hidden — Phase-2+)
// Trending, best-sellers, recommendations
// ──────────────────────────────────────────────

model ProductAnalytics {
  id          String    @id @default(uuid())
  productId   String    @unique
  views       Int       @default(0)
  orders      Int       @default(0)
  lastViewed  DateTime?
  lastOrdered DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([views])
  @@index([orders])
  @@index([lastViewed])
  @@map("product_analytics")
}

// ──────────────────────────────────────────────
// INVENTORY ALERTS (Hidden — Phase-2+)
// Near-expiry & out-of-stock intelligence
// ──────────────────────────────────────────────

model InventoryAlert {
  id        String    @id @default(uuid())
  productId String
  batchId   String?
  alertType AlertType
  message   String
  createdAt DateTime  @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([batchId])
  @@index([alertType])
  @@index([createdAt])
  @@map("inventory_alerts")
}

// ──────────────────────────────────────────────
// SELLER SETTLEMENTS (Payout tracking)
// ──────────────────────────────────────────────

model SellerSettlement {
  id              String    @id @default(uuid())
  sellerId        String
  orderItemId     String
  amount          Float
  commission      Float     @default(0)
  payoutStatus    String    @default("PENDING") // PENDING | PROCESSED | PAID
  payoutReference String?
  payoutDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  seller    SellerProfile @relation(fields: [sellerId], references: [id])
  orderItem OrderItem     @relation(fields: [orderItemId], references: [id])

  @@unique([orderItemId]) // One settlement per order item
  @@index([sellerId])
  @@index([payoutStatus])
  @@map("seller_settlements")
}

// ──────────────────────────────────────────────
// BLOG SYSTEM (SEO-Optimized CMS)
// ──────────────────────────────────────────────

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogAuthor {
  id        String   @id @default(uuid())
  name      String
  bio       String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_authors")
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id              String     @id @default(uuid())
  title           String
  slug            String     @unique
  excerpt         String?
  content         Json       // Editor.js JSON or rich text
  featuredImage   String?
  images          String[]   @default([])

  authorId        String
  categoryId      String
  tags            String[]   @default([])

  status          BlogStatus @default(DRAFT)

  // SEO Fields
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]   @default([])
  canonicalUrl    String?
  ogImage         String?

  // Analytics / UX
  readingTime     Int        @default(0)
  views           Int        @default(0)

  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author   BlogAuthor   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([views])
  @@index([status, publishedAt])
  @@map("blog_posts")
}
