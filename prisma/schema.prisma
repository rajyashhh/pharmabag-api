// ============================================================
// PharmaBag - B2B Pharmaceutical Marketplace
// Production-Grade PostgreSQL Schema (Prisma ORM)
// Designed for 100k–1M+ daily users, multi-vendor commerce
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  NEW
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PLACED
  ACCEPTED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  SUCCESS
  FAILED
}

enum PaymentMethod {
  BANK_TRANSFER
  UPI
  COD
  PARTIAL
  CREDIT
}

enum PaymentVerificationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AlertType {
  NEAR_EXPIRY
  OUT_OF_STOCK
}

enum DiscountType {
  PTR_DISCOUNT
  SAME_PRODUCT_BONUS
  PTR_PLUS_SAME_PRODUCT_BONUS
  DIFFERENT_PRODUCT_BONUS
  PTR_PLUS_DIFFERENT_PRODUCT_BONUS
}

enum ProductApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum CreditTier {
  PREPAID
  EMI
  FULLCREDIT
}

enum MigrationEntityType {
  USER
  ORDER
  PAYMENT
  ORDER_ITEM
  SETTLEMENT
}

enum MigrationStatus {
  RUNNING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum MigrationRecordStatus {
  SUCCESS
  SKIPPED
  FAILED
}

// ──────────────────────────────────────────────
// CORE IDENTITY
// ──────────────────────────────────────────────

model User {
  id        String     @id @default(uuid())
  phone     String     @unique
  email     String?    @unique
  password  String
  role      Role
  status    UserStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // One-to-one profiles
  buyerProfile  BuyerProfile?
  sellerProfile SellerProfile?
  adminProfile  AdminProfile?

  // Relations
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  tickets       Ticket[]
  messages      Message[]
  legacyId      String?        @unique

  @@index([role])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("users")
}

// ──────────────────────────────────────────────
// BUYER PROFILE
// ──────────────────────────────────────────────

model BuyerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  legalName          String
  gstNumber          String?            // Optional — either GST or PAN required
  panNumber          String?            // Optional — either GST or PAN required
  drugLicenseNumber  String?
  drugLicenseUrl     String?            // S3 URL to uploaded license document
  address            Json?              // { street1, street2?, city, state, pincode }
  city               String?
  state              String?
  pincode            String?
  latitude           Float?             // For nearby seller search
  longitude          Float?             // For nearby seller search
  gstPanResponse     Json?              // IDFY verification response: { status, legalName, gstNumber, message, ... }
  licence            Json?              // [{ type: "DL20B", number, expiry, imgUrl }, { type: "DL21B", ... }]
  bankAccount        Json?              // { accountNumber, ifsc, bankName, branch, holderName }
  cancelCheck        String?            // S3 URL — cancelled cheque image
  document           String?            // S3 URL — extra supporting document
  inviteCode         String?            // Referral / invite code
  verificationStatus VerificationStatus @default(UNVERIFIED)
  creditTier         CreditTier?        // null=pending(status 0), PREPAID(1), EMI(2), FULLCREDIT(3)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([state])
  @@index([pincode])
  @@index([verificationStatus])
  @@index([creditTier])
  @@map("buyer_profiles")
}

// ──────────────────────────────────────────────
// SELLER PROFILE
// ──────────────────────────────────────────────

model SellerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  companyName        String
  gstNumber          String
  panNumber          String
  drugLicenseNumber  String
  drugLicenseUrl     String // S3 URL to uploaded license document
  address            String
  city               String
  state              String
  pincode            String
  isVacation         Boolean            @default(false)
  rating             Float              @default(0)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  gstPanResponse     Json? // IDFY verification response: { status: true/false, legalName, gstNumber, message, ... }
  creditTier         CreditTier? // null=not approved, PREPAID(legacy 1), EMI(legacy 2), FULLCREDIT(legacy 3)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]
  orderItems  OrderItem[]
  settlements SellerSettlement[]

  @@index([city])
  @@index([state])
  @@index([verificationStatus])
  @@index([creditTier])
  @@index([isVacation])
  @@map("seller_profiles")
}

// ──────────────────────────────────────────────
// ADMIN PROFILE
// ──────────────────────────────────────────────

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String
  department  String?
  permissions String   @default("")  // Space-separated permission codes: "1 3 5 7 x" where x=super-admin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_profiles")
}

// ──────────────────────────────────────────────
// CATEGORY SYSTEM (Hierarchical)
// ──────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  subCategories SubCategory[]
  products      Product[]

  @@map("categories")
}

model SubCategory {
  id         String   @id @default(uuid())
  name       String
  slug       String
  categoryId String
  createdAt  DateTime @default(now())

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([slug, categoryId])
  @@index([categoryId])
  @@map("sub_categories")
}

// ──────────────────────────────────────────────
// PRODUCT CATALOG
// ──────────────────────────────────────────────

model Product {
  id                   String                @id @default(uuid())
  sellerId             String
  categoryId           String
  subCategoryId        String
  name                 String
  slug                 String?               @unique
  externalId           String?               @unique
  manufacturer         String
  chemicalComposition  String
  description          String?
  mrp                  Float
  gstPercent           Float
  minimumOrderQuantity Int                   @default(1)
  maximumOrderQuantity Int?
  discountType         DiscountType?
  discountMeta         Json?
  approvalStatus       ProductApprovalStatus @default(PENDING)
  rejectionReason      String?
  isActive             Boolean               @default(false)
  deletedAt            DateTime?             // Soft delete
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  seller      SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category    Category       @relation(fields: [categoryId], references: [id])
  subCategory SubCategory    @relation(fields: [subCategoryId], references: [id])
  batches     ProductBatch[]
  images      ProductImage[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]

  // Hidden infrastructure (Phase-2+)
  searchIndex     ProductSearchIndex?
  analytics       ProductAnalytics?
  inventoryAlerts InventoryAlert[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([name])
  @@index([manufacturer])
  @@index([deletedAt])
  @@index([externalId])
  @@index([name, manufacturer])
  @@index([categoryId, subCategoryId])
  @@map("products")
}

// ──────────────────────────────────────────────
// PRODUCT IMAGES
// ──────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String // S3 URL
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ──────────────────────────────────────────────
// CART SYSTEM
// ──────────────────────────────────────────────

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId]) // Prevent duplicate products in same cart
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ──────────────────────────────────────────────
// ORDER SYSTEM (Multi-Seller Support)
// ──────────────────────────────────────────────

model Order {
  id            String        @id @default(uuid())
  buyerId       String
  totalAmount   Float
  orderStatus   OrderStatus   @default(PLACED)
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  legacyId      String?        @unique

  buyer    User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  address  OrderAddress?
  items    OrderItem[]
  payments Payment[]

  @@index([buyerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  sellerId   String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  legacyId   String?   @unique

  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id])
  seller     SellerProfile     @relation(fields: [sellerId], references: [id])
  settlement SellerSettlement?

  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
  @@map("order_items")
}

// ──────────────────────────────────────────────
// PAYMENT SYSTEM
// ──────────────────────────────────────────────

model Payment {
  id                 String                    @id @default(uuid())
  orderId            String
  amount             Float
  method             PaymentMethod
  referenceNumber    String?
  proofUrl           String?
  verificationStatus PaymentVerificationStatus @default(PENDING)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  legacyId           String?                   @unique

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([verificationStatus])
  @@map("payments")
}

// ──────────────────────────────────────────────
// REVIEWS
// ──────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // One review per user per product
  @@index([productId])
  @@index([rating])
  @@map("reviews")
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// SUPPORT TICKET SYSTEM
// ──────────────────────────────────────────────

model Ticket {
  id        String       @id @default(uuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model Message {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("messages")
}

// ──────────────────────────────────────────────
// ORDER ADDRESS (Delivery snapshot)
// ──────────────────────────────────────────────

model OrderAddress {
  id      String @id @default(uuid())
  orderId String @unique
  name    String
  phone   String
  address String
  city    String
  state   String
  pincode String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

// ──────────────────────────────────────────────
// PRODUCT BATCHES (Pharma inventory tracking)
// ──────────────────────────────────────────────

model ProductBatch {
  id          String   @id @default(uuid())
  productId   String
  batchNumber String
  expiryDate  DateTime
  stock       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryAlerts InventoryAlert[]

  @@index([productId])
  @@index([expiryDate])
  @@index([productId, batchNumber])
  @@map("product_batches")
}

// ──────────────────────────────────────────────
// PRODUCT SEARCH INDEX (Hidden — Phase-2+)
// Fast full-text search & autocomplete
// ──────────────────────────────────────────────

model ProductSearchIndex {
  id                  String   @id @default(uuid())
  productId           String   @unique
  name                String
  manufacturer        String
  chemicalComposition String
  categoryName        String
  subCategoryName     String
  searchVector        String // Concatenated lowercase search string
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([manufacturer])
  @@index([searchVector])
  @@index([categoryName])
  @@map("product_search_index")
}

// ──────────────────────────────────────────────
// PRODUCT ANALYTICS (Hidden — Phase-2+)
// Trending, best-sellers, recommendations
// ──────────────────────────────────────────────

model ProductAnalytics {
  id          String    @id @default(uuid())
  productId   String    @unique
  views       Int       @default(0)
  orders      Int       @default(0)
  lastViewed  DateTime?
  lastOrdered DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([views])
  @@index([orders])
  @@index([lastViewed])
  @@map("product_analytics")
}

// ──────────────────────────────────────────────
// INVENTORY ALERTS (Hidden — Phase-2+)
// Near-expiry & out-of-stock intelligence
// ──────────────────────────────────────────────

model InventoryAlert {
  id        String    @id @default(uuid())
  productId String
  batchId   String?
  alertType AlertType
  message   String
  createdAt DateTime  @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([batchId])
  @@index([alertType])
  @@index([createdAt])
  @@map("inventory_alerts")
}

// ──────────────────────────────────────────────
// SELLER SETTLEMENTS (Payout tracking)
// ──────────────────────────────────────────────

model SellerSettlement {
  id              String    @id @default(uuid())
  sellerId        String
  orderItemId     String
  amount          Float
  commission      Float     @default(0)
  payoutStatus    String    @default("PENDING") // PENDING | PROCESSED | PAID
  payoutReference String?
  payoutDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  seller    SellerProfile @relation(fields: [sellerId], references: [id])
  orderItem OrderItem     @relation(fields: [orderItemId], references: [id])

  @@unique([orderItemId]) // One settlement per order item
  @@index([sellerId])
  @@index([payoutStatus])
  @@map("seller_settlements")
}

// ──────────────────────────────────────────────
// BLOG SYSTEM
// ──────────────────────────────────────────────

model BlogAuthor {
  id        String   @id @default(uuid())
  name      String
  bio       String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_authors")
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id              String     @id @default(uuid())
  title           String
  slug            String     @unique
  excerpt         String?
  content         Json
  featuredImage   String?
  images          String[]   @default([])
  authorId        String
  categoryId      String
  tags            String[]   @default([])
  status          BlogStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]   @default([])
  canonicalUrl    String?
  ogImage         String?
  readingTime     Int        @default(0)
  views           Int        @default(0)
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author   BlogAuthor   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([views])
  @@index([status, publishedAt])
  @@map("blog_posts")
}

// ──────────────────────────────────────────────
// MIGRATION PIPELINE
// ──────────────────────────────────────────────

model MigrationRun {
  id           String              @id @default(uuid())
  entityType   MigrationEntityType
  status       MigrationStatus     @default(RUNNING)
  totalRecords Int                 @default(0)
  successCount Int                 @default(0)
  failedCount  Int                 @default(0)
  skippedCount Int                 @default(0)
  metadata     Json?
  errorSummary String?
  startedAt    DateTime            @default(now())
  completedAt  DateTime?
  rolledBackAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  records MigrationRecord[]

  @@index([entityType])
  @@index([status])
  @@index([startedAt])
  @@map("migration_runs")
}

model MigrationRecord {
  id           String                @id @default(uuid())
  runId        String
  entityType   MigrationEntityType
  legacyId     String
  newId        String?
  status       MigrationRecordStatus @default(SUCCESS)
  errorMessage String?
  rawData      Json?
  createdAt    DateTime              @default(now())

  run MigrationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([entityType, legacyId])
  @@index([runId])
  @@index([entityType, legacyId])
  @@index([entityType, newId])
  @@index([status])
  @@map("migration_records")
}

model MigrationIdMap {
  id         String              @id @default(uuid())
  entityType MigrationEntityType
  legacyId   String
  newId      String
  createdAt  DateTime            @default(now())

  @@unique([entityType, legacyId])
  @@index([entityType, newId])
  @@map("migration_id_map")
}
